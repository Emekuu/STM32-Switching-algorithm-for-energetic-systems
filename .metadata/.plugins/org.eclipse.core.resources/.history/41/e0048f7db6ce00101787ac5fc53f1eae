    case P2PS_STM_WRITE_EVT:
/* USER CODE BEGIN P2PS_STM_WRITE_EVT */
    	/* USER CODE BEGIN P2PS_STM_WRITE_EVT /
    	{
    	/ 1) skopíruj prijaté dáta do textového buffra */
    	char rx_buf;​
    	uint8_t len = pNotification->DataTransfered.Length;
    	if (len >= sizeof(rx_buf))
    	{
    	len = sizeof(rx_buf) - 1;
    	}
    	memcpy(rx_buf, pNotification->DataTransfered.pPayload, len);
    	rx_buf[len] = '\0';

    	/* 2) priprav odpoveďový buffer */
    	char tx_buf = {0};​

    	/* 3) porovnanie príkazu */
    	if (strncmp(rx_buf, "LED_ON", 6) == 0)
    	{
    	BSP_LED_On(LED_BLUE);
    	strcpy(tx_buf, "LED_ON_OK");
    	}
    	else if (strncmp(rx_buf, "LED_OFF", 7) == 0)
    	{
    	BSP_LED_Off(LED_BLUE);
    	strcpy(tx_buf, "LED_OFF_OK");
    	}
    	else
    	{
    	strcpy(tx_buf, "UNKNOWN");
    	}

    	/* 4) pošli odpoveď späť klientovi cez notify charakteristiku */
    	if (P2P_Server_App_Context.Notification_Status)
    	{
    	P2PS_STM_App_Update_Char(P2P_NOTIFY_CHAR_UUID,
    	(uint8_t )tx_buf);
    	}
    	}

/* USER CODE END P2PS_STM_WRITE_EVT */
      break;

    default:
/* USER CODE BEGIN P2PS_STM_App_Notification_default */

/* USER CODE END P2PS_STM_App_Notification_default */
      break;
  }
/* USER CODE BEGIN P2PS_STM_App_Notification_2 */

/* USER CODE END P2PS_STM_App_Notification_2 */
  return;
}

